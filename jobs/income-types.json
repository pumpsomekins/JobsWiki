{
  "_version": "v4.1",
  "_note": "Income types classified by labor trigger event + payment structure. No asset-passive income. 21 active labor types. hasBasePayToggle=true types carry full toggle metadata for UI rendering. salary_plus_equity includes phantom share variants (Huawei ESOP + TUP). All occupation JSONs must reference incomeType from this registry.",

  "salary": {
    "label": "Fixed Annual Salary",
    "code": "salary",
    "laborBehavior": "Fixed full-time commitment",
    "triggerEvent": "Fixed annual salary",
    "icon": "🏢",
    "structure": "time-based / annual fixed",
    "classicOccupations": ["Engineer", "Teacher", "Nurse", "Accountant", "Manager"],
    "bonusApplicable": true,
    "bonusRange": [0.05, 0.30],
    "hasBasePayToggle": false,
    "inflationSensitive": true,
    "timeAutonomy": "LOW",
    "incomeFlexibility": "FIXED",
    "calculatorInputs": ["annualSalary", "careerYears", "bonusRate", "inflationRate", "taxRate"],
    "ltv_base":      "annualSalary × careerYears",
    "ltv_bonus":     "annualSalary × careerYears × (1 + bonusRate)",
    "ltv_inflation": "annualSalary × Σ(1 + inflationRate)^year",
    "ltv_aftertax":  "ltv_bonus × (1 - taxRate)"
  },

